class Solution {
    int missingNum(int arr[]) {
        // code here
        int i=0;
        while(i<arr.length)
        {
            int c = arr[i]-1;
            if(arr[i]>0  && arr[i]<=arr.length && arr[i]!=arr[c]){
                int t = arr[i];
                arr[i] = arr[c];
                arr[c] = t;
            }
            else i++;
        }
        for(int j=0;j<arr.length;j++){
            if(arr[j]!=j+1) return j+1;
        }
        return arr.length+1;
    }
}
