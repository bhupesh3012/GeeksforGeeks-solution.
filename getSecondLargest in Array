class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int max = arr[0];
        int sec = -1;
        for(int i:arr){
            if(i>max){
                sec = max;
                max = i;
            
            }
            else if(i>sec && i<max) sec = i;
        }
        
        return sec;
    }
}
